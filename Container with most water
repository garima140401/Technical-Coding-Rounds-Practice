//Container with most water:
class Solution{
public int container(int []height){
int left=0;
int right = height.length-1;
int maxArea=0;
while(left<right){
int area = min(height[left], height[right])*(right-left);
maxArea= Math.max(maxArea, area);
if(height[left]<height[right]){
left++;
}
else{
right--;
}
}
return maxArea;
}
}
