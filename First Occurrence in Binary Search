//2.First Occurrence of the target in the array:
class Solution{
public int firstOccurence(int[] arr, int target){
int left=0; int ans=-1;
int right =arr.length-1;
while(left<=right){
int mid = left+(right-left)/2;
if(arr[mid]==target){
ans=mid;
right=mid-1;
}
else if(arr[mid]>target){
right = mid-1;
}
else{
left= mid+1;
}
}
return ans;
}
}
