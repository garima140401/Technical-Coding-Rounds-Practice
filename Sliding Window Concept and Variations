6. Kadane algorithm: 
// for this, we have to make two variables, one currentsum and one maxsum:
//main crux: until the sum remains positive, expand the window, and when it becomes negative restart again:
class Solution{
public int kadaneAlgo(int[] arr){
int currentSum= arr[0];
int maxSum= arr[0];
for(int i=1; i<arr.length; i++){
currentSum = Math.max(arr[i], currentSum+arr[i]);

//update max:
maxSum = Math.max(maxSum, currentSum);
}
return maxSum;
}
}
