//3. Finding last occurrence in a sorted Array Variation of B.S.
class Solution{
public int lastOccurence(int[]arr, int target){
int ans=-1;
int left=0; 
int right = arr.length-1;
while(left<=right){
int mid= left+(right-left)/2;
if(arr[mid]==target){
ans= mid;
left=mid+1;
}
else if(arr[mid]>target){
right=mid-1;
}
else{
left=mid+1;
}
}
return ans;
}
}
